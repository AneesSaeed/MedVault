<?xml version="1.0" encoding="UTF-8"?>
<configuration>
  <!-- Default Spring Boot configuration is imported -->
  <include resource="org/springframework/boot/logging/logback/defaults.xml"/>
  
  <!-- Define a JSON layout for structured logging -->
  <property name="LOG_FILE" value="${LOG_FILE:-${LOG_PATH:-${LOG_TEMP:-${java.io.tmpdir:-/tmp}}/}spring.log}"/>
  
  <!-- Console appender (development) -->
  <appender name="CONSOLE" class="ch.qos.logback.core.ConsoleAppender">
    <encoder>
      <pattern>${CONSOLE_LOG_PATTERN}</pattern>
      <charset>utf8</charset>
    </encoder>
  </appender>

  <!-- File appender (local backup) -->
  <appender name="FILE" class="ch.qos.logback.core.rolling.RollingFileAppender">
    <file>${LOG_FILE}</file>
    <encoder>
      <pattern>${FILE_LOG_PATTERN}</pattern>
      <charset>utf8</charset>
    </encoder>
    <rollingPolicy class="ch.qos.logback.core.rolling.SizeAndTimeBasedRollingPolicy">
      <fileNamePattern>${LOG_PATH:-${LOG_TEMP:-${java.io.tmpdir:-/tmp}}/}spring-%d{yyyy-MM-dd}.%i.log</fileNamePattern>
      <maxFileSize>10MB</maxFileSize>
      <maxHistory>30</maxHistory>
      <totalSizeCap>1GB</totalSizeCap>
    </rollingPolicy>
  </appender>

  <!-- Logstash TCP appender (sends to Logstash on port 5000) -->
  <appender name="LOGSTASH" class="net.logstash.logback.appender.LogstashTcpSocketAppender">
    <!-- Logstash TCP input host/port -->
    <destination>logstash:5000</destination>
    
    <!-- Use LogstashEncoder for JSON formatting -->
    <encoder class="net.logstash.logback.encoder.LogstashEncoder">
      <!-- Include custom fields -->
      <customFields>{"application":"healthsec","environment":"development","version":"1.0.0"}</customFields>
      <!-- Include thread name -->
      <includeContext>true</includeContext>
      <!-- Include MDC (Mapped Diagnostic Context) for correlation IDs -->
      <includeMdc>true</includeMdc>
    </encoder>
    
    <!-- Ring buffer for high-volume logging -->
    <ringBufferSize>512</ringBufferSize>
    
    <!-- Connection retry policy -->
    <reconnectionDelay>10000</reconnectionDelay>
  </appender>

  <!-- Async appender for Logstash (non-blocking) -->
  <appender name="ASYNC_LOGSTASH" class="ch.qos.logback.classic.AsyncAppender">
    <ringBufferSize>512</ringBufferSize>
    <appender-ref ref="LOGSTASH"/>
  </appender>

  <!-- Spring profiles -->
  <springProfile name="dev,default">
    <!-- Development: log everything, send to Logstash and console -->
    <root level="INFO">
      <appender-ref ref="CONSOLE"/>
      <appender-ref ref="FILE"/>
      <appender-ref ref="ASYNC_LOGSTASH"/>
    </root>
    
    <!-- Spring Boot default loggers -->
    <logger name="org.springframework.web" level="DEBUG"/>
    <logger name="org.springframework.security" level="DEBUG"/>
    <logger name="be.he2b.healthsec" level="DEBUG"/>
  </springProfile>

  <springProfile name="prod">
    <!-- Production: INFO level, send to Logstash (async), log to file -->
    <root level="INFO">
      <appender-ref ref="FILE"/>
      <appender-ref ref="ASYNC_LOGSTASH"/>
    </root>
    
    <!-- Reduce Spring verbosity in production -->
    <logger name="org.springframework" level="WARN"/>
    <logger name="org.springframework.web" level="INFO"/>
    <logger name="org.springframework.security" level="WARN"/>
    
    <!-- HealthSec loggers -->
    <logger name="be.he2b.healthsec" level="INFO"/>
    <logger name="be.he2b.healthsec.medical_records.logging" level="DEBUG"/>
    <logger name="be.he2b.healthsec.medical_records.security" level="DEBUG"/>
  </springProfile>
</configuration>
